// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  role          String   @default("cliente")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Preferencias
  preferencias  Json?    @default("{}") // {"sonidoNotificaciones": true}

  // Datos de facturación persistentes
  tipoDocumento String? // "dni" | "ruc" | "ce"
  numeroDoc     String?
  direccion     String?
  celular       String? // Teléfono de uso general

  sessions         Session[]
  accounts         Account[]
  carrito          Carrito[]
  pedidos          Pedido[]
  reclamos         Reclamo[]
  notificaciones   Notificacion[]
  metrajeEtiquetas MetrajeEtiqueta[]
  feedback         Feedback[]
  atiendeReclamos  Reclamo[] @relation("ReclamoAtendido")
  tiendas                Tienda[]
  almacenes              Almacen[]
  pedidosDelegados       PedidoDelegado[]
  favoritos              Favorito[]
  datosFacturacion       DatosFacturacion[]
  datosDireccionEnvios   DatosDireccionEnvios[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Producto {
  id            String          @id @default(cuid())
  nombre        String          @unique
  categoria     String          @default("MANCHESTER SUITING")
  descripcion   String?
  precio        Float
  imagen        String?
  proveedorId   String?
  activo        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  carrito       Carrito[]
  pedidoDetalle PedidoDetalle[]
  stocks        ProductoStock[]
  favoritos     Favorito[]

  @@map("producto")
}

model Almacen {
  id            String          @id @default(cuid())
  nombre        String
  direccion     String
  telefono      String?
  responsableId String?
  ciudad        String?
  activo        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now())
  responsable   User?           @relation(fields: [responsableId], references: [id])
  stocks        ProductoStock[]

  @@index([responsableId])
  @@map("almacen")
}

model ProductoStock {
  id         String   @id @default(cuid())
  productoId String
  almacenId  String
  stock      Int      @default(0)
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  almacen    Almacen  @relation(fields: [almacenId], references: [id], onDelete: Cascade)

  @@unique([productoId, almacenId])
  @@map("producto_stock")
}

model Favorito {
  id         String   @id @default(cuid())
  userId     String
  productoId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([userId, productoId])
  @@index([userId])
  @@map("favorito")
}

model Carrito {
  id                String   @id @default(cuid())
  userId            String
  productoId        String
  cantidad          Float    @default(1)
  tipo              String   @default("metros") // "metros" or "pieza"
  indicacionesCorte String? // Indicaciones de corte (máx 200 caracteres)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  producto          Producto @relation(fields: [productoId], references: [id])

  @@unique([userId, productoId, tipo])
  @@index([userId])
  @@map("carrito")
}

model Pedido {
  id          String @id @default(cuid())
  userId      String
  numeroOrden String @unique // "ORD-2026-0001"
  estado      String @default("metraje_en_proceso")
  // Estados: metraje_en_proceso | metraje_confirmado | pendiente | confirmado | completado
  total       Float

  // Datos de facturación
  tipoDocumento String? // "dni" | "ruc" | "ce"
  numeroDoc     String?
  nombreFactura String?
  direccion     String?

  // Método de envío
  metodoEnvio  String? // "tienda" | "agencia" | "delivery"
  tiendaId     String?
  tienda       Tienda? @relation(fields: [tiendaId], references: [id])
  tipoEnvio    String? // "mismapersona" | "otropersona" (para agencia/delivery)
  agencia      String? // "shalom" | "flores" | "marvisur" | "otros"
  agenciaOtro  String?
  delivery     String? // "olva" | "safexpress" | "otros"
  deliveryOtro String?
  departamento String?
  provincia    String?
  distrito     String?
  costoEnvio   Float   @default(0)

  // Datos de quien recibe (para otra persona)
  dniRecibe     String?
  nombreRecibe  String?
  celularRecibe String?

  // Pago
  numeroOperacion String?
  notas           String?
  comprobantePago String? // URL del comprobante de pago (Cloudinary)

  // Delegación y seguimiento
  motivoRechazo String? // Motivo cuando se rechaza
  delegados     PedidoDelegado[]
  feedback       Feedback[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pedidoDetalle  PedidoDetalle[]
  reclamos       Reclamo[]
  notificaciones Notificacion[]

  @@index([userId])
  @@map("pedido")
}

model PedidoDetalle {
  id                String            @id @default(cuid())
  pedidoId          String
  productoId        String
  cantidad          Float // Cantidad original (piezas o metros)
  tipo              String            @default("metros") // "metros" | "pieza"
  metraje           Float? // Metraje exacto en metros (cuando admin_edita)
  precio            Float
  indicacionesCorte String? // Indicaciones de corte para este item (máx 200 caracteres)
  pedido            Pedido            @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto          Producto          @relation(fields: [productoId], references: [id])
  etiquetas         MetrajeEtiqueta[]

  @@index([pedidoId])
  @@map("pedido_detalle")
}

model MetrajeEtiqueta {
  id        String        @id @default(cuid())
  detalleId String
  valor     Float
  userId    String? // Usuario que crea la etiqueta de metraje
  createdAt DateTime      @default(now())
  detalle   PedidoDetalle @relation(fields: [detalleId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id])

  @@index([detalleId])
  @@index([userId])
  @@map("metraje_etiqueta")
}

model Reclamo {
  id            String   @id @default(cuid())
  userId        String
  pedidoId      String?
  tipo          String   // "queja" | "reclamo"
  descripcion   String
  detalle_pedido String?  // detalle adicional sobre el problema
  estado        String   @default("pendiente")
  respuesta     String?
  atendidoPorId String?
  atendidoPor   User?   @relation("ReclamoAtendido", fields: [atendidoPorId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pedido        Pedido?  @relation(fields: [pedidoId], references: [id])

  @@index([userId])
  @@index([pedidoId])
  @@index([tipo])
  @@index([atendidoPorId])
  @@map("reclamo")
}

model Feedback {
  id          String   @id @default(cuid())
  pedidoId    String
  userId      String
  calificacion Int      // 0-5 estrellas (requerido)
  comentario  String?   // opcional
  etiquetas   String?   // opcional (separadas por coma)
  createdAt   DateTime @default(now())
  pedido      Pedido   @relation(fields: [pedidoId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([pedidoId])
  @@index([userId])
  @@map("feedback")
}

model Notificacion {
  id        String   @id @default(cuid())
  userId    String
  tipo      String // "metraje_confirmado" | "pedido_estado" | "sistema" | "pedido"
  titulo    String
  mensaje   String
  pedidoId  String?
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pedido    Pedido?  @relation(fields: [pedidoId], references: [id])

  @@index([userId])
  @@index([userId, leida])
  @@map("notificacion")
}

model Tienda {
  id          String   @id @default(cuid())
  nombre      String
  direccion   String
  referencia  String?
  encargadoId String
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  encargado User     @relation(fields: [encargadoId], references: [id])
  pedidos   Pedido[]

  @@index([encargadoId])
  @@map("tienda")
}

model PedidoDelegado {
  id        String   @id @default(cuid())
  pedidoId  String
  userId    String
  createdAt DateTime @default(now())

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([pedidoId, userId]) // Un empleado solo puede ser asignado una vez por pedido
  @@index([pedidoId])
  @@index([userId])
  @@map("pedido_delegado")
}

model DatosFacturacion {
  id             String   @id @default(cuid())
  userId         String
  nombre         String   // "Plantilla facturación", "Plantilla facturación 2", etc.

  // Datos de facturación
  tipoDocumento  String   // "dni" | "ruc" | "ce"
  numeroDoc      String
  nombreFactura  String
  razonSocial    String?  // Solo para RUC
  direccion      String?  // Dirección (para RUC o ubigeo)
  departamento  String?
  provincia      String?
  distrito       String?
  celular        String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("datos_facturacion")
}

model DatosDireccionEnvios {
  id             String   @id @default(cuid())
  userId         String
  nombre         String   // "Plantilla dirección de envío", "Plantilla dirección de envío 2", etc.

  // Método de envío
  metodoEnvio    String   // "agencia" | "delivery" (no "tienda")
  tiendaId       String?
  agencia        String?  // "shalom" | "flores" | "marvisur" | "olva" | "safexpress" | "otros"
  agenciaOtro    String?
  delivery       String?  // "olva" | "safexpress" | "otros"
  deliveryOtro   String?

  // Ubicación
  departamento   String?
  provincia      String?
  distrito       String?

  // Dirección de envío (nuevo campo para agencia/delivery)
  direccion      String?  // Dirección específica de entrega

  // Datos de quien recibe
  tipoEnvio      String?  // "mismapersona" | "otropersona"
  dniRecibe      String?
  nombreRecibe   String?
  celularRecibe  String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("datos_direccion_envios")
}

model ClientePedido {
  id              String   @id @default(cuid())
  nombre          String
  tipoDoc         String   // "dni" | "ruc" | "ce"
  numeroDoc       String
  razonSocial     String?  // para RUC
  direccion       String?
  telefono        String?
  agencia         String?  // "shalom" | "flores" | "marvisur" | "otros"
  agenciaOtro     String?
  guiaRemision    Boolean  @default(false)
  departamento   String?
  provincia       String?
  distrito       String?
  createdAt       DateTime @default(now())

  @@index([numeroDoc])
  @@map("cliente_pedido")
}
